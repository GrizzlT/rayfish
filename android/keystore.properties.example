# Release signing config for the app module. Copy this file to
# keystore.properties (same directory) and fill in real values. The real
# keystore.properties and any .jks/.keystore file are gitignored; never commit
# them.
#
# Generate an upload keystore with:
#   keytool -genkeypair -v -keystore rayfish-upload.jks \
#     -keyalg RSA -keysize 2048 -validity 10000 -alias rayfish
#
# For Play App Signing, this is your upload key: Google re-signs with the app
# signing key it holds, so losing this only means requesting an upload-key reset,
# not losing the app.

storeFile=rayfish-upload.jks
storePassword=CHANGE_ME
keyAlias=rayfish
keyPassword=CHANGE_ME
